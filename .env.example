# Pflicht — ohne diese Werte startet die Anwendung nicht.
BASE_URL=https://dashboard.example.com
OIDC_ISSUER=https://id.example.com
OIDC_CLIENT_ID=dashmyboard
OIDC_CLIENT_SECRET=change-me

# Optional
OIDC_NAME=Single Sign-On     # Name des Anbieters, erscheint auf der Anmeldekarte
ADMIN_ROLE=admin             # OIDC-Gruppe, die bearbeiten darf
DATA_DIR=/data               # Inhalte, Logos, Hintergrundbilder
DB_PATH=/data/tinysesam.db   # Sitzungen und Nutzer
HTTPS_MODE=warn                                        # "warn" hinter TLS-Proxy, "require" bei direktem HTTPS
TRUSTED_PROXIES=127.0.0.1/32,::1/128,172.16.0.0/12     # nur diesen Gegenstellen wird X-Forwarded-For geglaubt
