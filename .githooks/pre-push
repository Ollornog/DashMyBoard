#!/usr/bin/env bash
# Letzte Bremse vor dem Push: die Suite läuft im Container (ci-local), nicht auf dem Host.
#
# Auf Feature-Branches gibt es keine GitHub-CI — der Container-Lauf ist dort die einzige
# Prüfung. Ein stiller Rückfall auf den Host wäre ein Loch im Netz. Ausnahme: beim Push
# auf main genügt der native Lauf, weil dort anschließend die GitHub-CI greift.
set -euo pipefail

auf_main=0
while read -r _local_ref _local_sha remote_ref _remote_sha; do
    [[ "$remote_ref" == "refs/heads/main" ]] && auf_main=1
done

if command -v ci-local >/dev/null 2>&1; then
    exec ci-local --full
fi

if [[ $auf_main -eq 1 ]]; then
    echo "pre-push: ci-local fehlt — nativer Lauf, GitHub-CI greift auf main." >&2
    # Kein `exec`: den Rückstands-Check macht sonst niemand. Er steckt in ci-local,
    # und wer nativ läuft, bekäme ihn nie — eine Suite, die Dateien liegen lässt,
    # fiele erst in der CI auf.
    vorher="$(git status --porcelain)"
    ./scripts/check.sh || exit 1
    nachher="$(git status --porcelain)"
    if [[ "$vorher" != "$nachher" ]]; then
        echo "pre-push: die Suite hat Rückstände hinterlassen:" >&2
        diff <(printf '%s\n' "$vorher") <(printf '%s\n' "$nachher") >&2 || true
        exit 1
    fi
    exit 0
fi

echo "pre-push: ci-local fehlt und dies ist kein Push auf main." >&2
echo "          Auf Feature-Branches läuft keine CI — der Container-Lauf ist Pflicht." >&2
exit 1
